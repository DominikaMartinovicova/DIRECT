#+++++++++++++++++++++++++++++++++++++++ 0 PREPARE WILDCARDS AND TARGET ++++++++++++++++++++++++++++++++++++++++++++
# Prepare functions to get dynamic wildcards for patch-level spatial analysis
#-------------------------------------------------------------------------------------------------------------------
def get_cores(wildcards):
    ckpts = checkpoints.core_level_adata.get()
    core_files = glob.glob(f'{ckpts.output.output_dir_cores}/T*.h5ad')
    return [file.split('/')[-1].replace('.h5ad','') for file in core_files]

def combine_inputs(wildcards):
    files = []
    cores = get_cores(wildcards)
    files += expand(output_dir_results + 'spatial/per_sample/{core}/centrality_scores.csv', core=cores)
    files += expand(output_dir_results + "spatial/per_sample/{core}/neighbors_enrichment.pkl",core=cores)
    files += expand(output_dir_results + "spatial/per_sample/{core}/interaction_matrix.pkl",core=cores)
    files += expand(output_dir_results + "spatial/per_sample/{core}/co_occurrence_probabilities.pkl",core=cores)
    return files

