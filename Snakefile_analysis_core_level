        -o {output.output_dir_cores} \
        """

#+++++++++++++++++++++++++++++++++++++++ 3 SPATIALLY ANALYZE XENIUM DATA ++++++++++++++++++++++++++++++++++++++++++++
# Spatial analysis per core or tissue piece
#-------------------------------------------------------------------------------------------------------------------
rule spatial_analysis_per_core:
    input:
        adata_core_subset = data_dir + f'adata_per_sample/{phenotyping_level}/{{core}}.h5ad'
    output:
        output_plot_dir = directory(output_dir_results + f'spatial/per_sample/{{core}}/'),
        centrality_scores = output_dir_results + f'spatial/per_sample/{{core}}/centrality_scores.csv',
        nhood_enrichment = output_dir_results + f"spatial/per_sample/{{core}}/neighbors_enrichment.pkl",
        interaction_matrix = output_dir_results + f"spatial/per_sample/{{core}}/interaction_matrix.pkl",
        co_occurrence = output_dir_results + f"spatial/per_sample/{{core}}/co_occurrence_probabilities.pkl",
        ripleys_L = output_dir_results + f'spatial/per_sample/{{core}}/dict_ripleys_L.pkl'
    params:
        celltype_key = phenotyping_level,
        celltype_list = data_dir + f"/combined/{phenotyping_level}_celltype_list.txt"
    #conda:
    #    "xenium_py310"
    shell:
        """
        python3 scripts/analysis_and_plotting/spatial_analysis.py \
        -i {input.adata_core_subset} \
        --celltype_key {params.celltype_key} \
        --celltype_list {params.celltype_list} \
        -o_results {output_dir_results}/spatial/per_sample/{wildcards.core}/ \
        -o_plots {output_dir_plots}/spatial/per_sample/{wildcards.core}/ \
        """

