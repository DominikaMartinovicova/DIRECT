        adata_path = data_dir + f"/combined/{phenotyping_level}_combined_adatas_for_analysis_w_v1.7.h5ad",
        in_dir = output_dir_results + 'spatial/per_sample/',
        out_dir_results = output_dir_results + 'spatial/combined/core_level/',
        metadata_path = data_dir + f"/adata_per_sample/{phenotyping_level}/samples_metadata.csv"
    #conda:
