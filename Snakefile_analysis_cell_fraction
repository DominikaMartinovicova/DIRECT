output_dir_plots = config["all"]["output_dir_plots"]
exclude_v17 = config["exclude_v17"]
if exclude_v17:
    ex_v17 = "wo_v1.7"
elif not exclude_v17:
    ex_v17 = "w_v1.7"

phenotyping_level = config["phenotyping_level"]
adata_path = config["adata_path"]
