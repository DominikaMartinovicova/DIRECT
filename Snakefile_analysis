
from scripts.analysis_and_plotting.utils import *
import glob
from snakemake.io import expand, dynamic

def get_patches(wildcards):
    ckpts = checkpoints.patching.get()
    patch_files = glob.glob(f'{ckpts.output.output_dir_patches}/patch_*.h5ad')
    return [file.split('/')[-1].replace('patch_', '').replace('.h5ad','') for file in patch_files]

def spatial_targets(wildcards):
    return expand(output_dir_results + 'spatial/per_patch/{patch_size}um_{overlap}um/{patch}/centrality_scores.csv',
                  patch=get_patches(wildcards), patch_size=patch_size, overlap=overlap)

def combine_inputs(wildcards):
    files = []
    patches = get_patches(wildcards)
    files += expand(output_dir_results + 'spatial/per_patch/{patch_size}um_{overlap}um/{patch}/centrality_scores.csv',
                              patch=patches, patch_size=patch_size, overlap=overlap)
    files += expand(output_dir_results + "spatial/per_patch/{patch_size}um_{overlap}um/{patch}/neighbors_enrichment.pkl",
                              patch=patches, patch_size=patch_size, overlap=overlap)
    files += expand(output_dir_results + "spatial/per_patch/{patch_size}um_{overlap}um/{patch}/interaction_matrix.pkl",
                               patch=patches, patch_size=patch_size, overlap=overlap)
    files += expand(output_dir_results + "spatial/per_patch/{patch_size}um_{overlap}um/{patch}/co_occurrence_probabilities.pkl",
                          patch=patches, patch_size=patch_size, overlap=overlap)
    return files

